# GameMaker Studio 2 - .gitignore

# ======================
# Sistema Operacional
# ======================

# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store
__MACOSX/

# ======================
# GameMaker
# ======================

# Arquivo de ordenação de assets (preferência local do usuário, não precisa ser versionado)
.resource_order

# Cache de build local
/cache/

# Builds geradas
/build/

# Pacotes de assets do Marketplace (não precisam ir ao repositório)
*.yymps
*.yymp
*.gmez

# ======================
# IDEs e Editores
# ======================

# Visual Studio Code
.vscode/

# JetBrains
.idea/

# ======================
# Logs
# ======================
*.log